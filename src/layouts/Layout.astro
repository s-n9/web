---
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'

const {
  title = 'SD',
  showNavbar = true,
  showFooter = true,
} = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/svg+xml" href="/d.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="container">
      { showNavbar && <Navbar /> }
      <main class="content">
        <slot />
      </main>
      { showFooter && <Footer /> }
    </div>
  </body>
</html>

<style>
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  margin-top: 3rem;
}
</style>
