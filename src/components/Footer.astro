---
interface SocialLink {
  href: string;
  label: string;
  paths: string[];
}

const socialLinks: SocialLink[] = [
  {
    href: 'https://github.com/s-n9',
    label: 'GitHub',
    paths: ['M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22']
  },
  {
    href: 'https://www.linkedin.com/in/sebastian-d-8b6120394',
    label: 'LinkedIn',
    paths: ['M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z', 'M2 9h4v12H2z', 'M4 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z']
  },
]
---
<footer class="footer">
  <div class="footer-content">
    <span class="name">SD</span>
    <div class="social-links" aria-label="Social media">
      {socialLinks.map(link=> (
        <a 
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label={link.label}
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            {link.paths.map(path => <path d={path} />)}
          </svg>        
        </a>
      ))}
    </div>
  </div>
</footer>

<style>
.footer {
  border-top: 1px solid var(--border);
  padding: 1.25rem 0;
  margin-top: auto;
  color: var(--muted)
}

.footer-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 2rem;
}

.name {
  font-size: 0.95rem;
  font-weight: 500;
}

.social-links {
  display: flex;
  gap: 1.25rem;
  align-items: center;
}

.social-link {
  color: var(--muted);
  transition: color 0.3s ease, transform 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.social-link:hover {
  color: var(--text);
  transform: translateY(-2px)
}

@media (max-width: 768px) {
  .footer-content {
    padding: 0 1rem;
  }
}

@media (max-width: 480px) {
  .footer-content {
    padding: 0 0.75rem;
    gap: 1rem;
  }

  .name {
    font-size: 0.9rem;
  }

  .social-links {
    gap: 1.5rem;
  }
}
</style>
